# EVACSIM — Environment Variables Example
# Copy this file to .env.local for local development, or add these variables to your Vercel project settings.

# Supabase Credentials
# Find these in your Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Public site URL
# Production: https://evacsim.vercel.app
# Local development override: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://evacsim.vercel.app

# Mapbox Token
# Required for the interactive campus map view
# Get a free public token from https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token-here
